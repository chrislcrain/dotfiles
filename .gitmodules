[submodule "ohmyzsh"]
	path = ohmyzsh
	url = https://github.com/ohmyzsh/ohmyzsh.git
[submodule ".zsh_custom/plugins/zsh-completions"]
	path = .zsh_custom/plugins/zsh-completions
	url = https://github.com/zsh-users/zsh-completions.git
[submodule ".zsh_custom/plugins/.zsh_custom/plugins/zsh-autosuggestions"]
	path = .zsh_custom/plugins/.zsh_custom/plugins/zsh-autosuggestions
	url = https://github.com/zsh-users/zsh-autosuggestions.git
