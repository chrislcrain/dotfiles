[submodule "ohmyzsh"]
	path = ohmyzsh
	url = https://github.com/ohmyzsh/ohmyzsh.git
[submodule ".zsh_custom/plugins/.zsh_customs/zsh-completions"]
	path = .zsh_custom/plugins/.zsh_customs/zsh-completions
	url = https://github.com/zsh-users/zsh-completions.git
[submodule ".zsh_custom/plugins/.zsh_customs/zsh-syntax-highlight"]
	path = .zsh_custom/plugins/.zsh_customs/zsh-syntax-highlight
	url = https://github.com/zsh-users/zsh-syntax-highlighting.git
[submodule ".zsh_custom/plugins/.zsh_customs/zsh-autosuggestions"]
	path = .zsh_custom/plugins/.zsh_customs/zsh-autosuggestions
	url = https://github.com/zsh-users/zsh-autosuggestions.git
