# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

{{- if eq .chezmoi.username "coder" }}
# On Coder, attach to (or create) the persistent `main` tmux session for
# every interactive shell so SSH and web-term sessions share state.
# tmux lives in ~/.local/bin, which .profile adds to PATH later — make it
# visible to `command -v` here so the guard doesn't silently skip.
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
  PATH="$HOME/.local/bin:$PATH"
fi

export LANG=C.UTF-8

if [[ -z "$TMUX" ]] && [[ $- == *i* ]] && [[ -z "$NVIM" ]] \
   && [[ "$TERM_PROGRAM" != "vscode" ]] && [[ -z "$NO_TMUX_AUTOSTART" ]] \
   && command -v tmux >/dev/null 2>&1; then
  exec tmux -u new-session -A -s main
fi
{{- end }}

DISABLE_AUTO_UPDATE="true"
ZSH_THEME="powerlevel10k/powerlevel10k"
export EDITOR="nvim"
if [[ -n "$NVIM" ]]; then
  export KEYTIMEOUT=50
else
  export KEYTIMEOUT=10
fi

plugins=(
  git
  poetry
  zsh-autosuggestions
  zsh-completions
  direnv
)

source $HOME/.profile
source $ZSH/oh-my-zsh.sh

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f "$HOME/.p10k.zsh" ]] || source "$HOME/.p10k.zsh"

# Setup fuzzyfinder
export FZF_SHELL_PATH="$XDG_CONFIG_HOME/fzf/shell"
source "$FZF_SHELL_PATH/completion.zsh"
source "$FZF_SHELL_PATH/key-bindings.zsh"

# Setup  pyenv
if command -v pyenv 1>/dev/null 2>&1; then
  eval "$(pyenv init -)"
fi

export PATH="$PATH:$HOME/.local/bin"

# Go toolchain + `go install` binaries (e.g. sedge)
export PATH="$PATH:$HOME/.local/go/bin:$HOME/go/bin"

{{- if eq .chezmoi.username "coder" }}
# Keep sedge state on /code so it survives Coder workspace rebuilds.
export SEDGE_HOME=/code/.sedge
{{- end }}

export CODER_SSH_FORWARD_AGENT=TRUE

source $XDG_CONFIG_HOME/ohmyzsh/.zsh_custom/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

{{ if eq .chezmoi.os "darwin" -}}
export SSH_AUTH_SOCK=$HOME/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
export PATH="$PATH:/Library/PostgreSQL/17/bin"
export PATH="$PATH:/Applications/WezTerm.app/Contents/MacOS"
export PATH="$PATH:$HOME/.config/lua/lua-5.1/src"
export PATH="$PATH:$HOME/.local/share/nvim/mason/bin"
{{- end }}

# direnv hook into shell (not necessary because it is a core plugin)
eval "$(direnv hook zsh)"
